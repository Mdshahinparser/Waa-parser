<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/>
<meta name="theme-color" content="#0d1b2a"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-title" content="WA Parser"/>
<title>WA Parser</title>
<link rel="icon" type="image/png" sizes="192x192" href="data:image/png;base64,"/>
<link rel="apple-touch-icon" sizes="180x180" href="data:image/png;base64,"/>
<style>
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent;margin:0;padding:0;}
body{background:linear-gradient(160deg,#0d1b2a,#1a2f45);min-height:100vh;font-family:'Segoe UI',Arial,sans-serif;color:#e0eefa;}
input,textarea,button{font-family:inherit;}
.card{background:#152030;border-radius:14px;border:1px solid #1e3a55;padding:18px;margin-bottom:14px;}
.sec{padding:8px 18px 3px;font-size:10px;color:#3a6a8a;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;}
</style>


<script>
try {
  var mBlob = new Blob([JSON.stringify({  \"name\": \"WA Parser\",  \"short_name\": \"WA Parser\",  \"description\": \"WhatsApp Transaction Parser\",  \"start_url\": \".\",  \"display\": \"standalone\",  \"orientation\": \"portrait\",  \"background_color\": \"#0d1b2a\",  \"theme_color\": \"#25d366\",  \"icons\": [    {\"src\": \"data:image/png;base64,\", \"sizes\": \"192x192\", \"type\": \"image/png\"},    {\"src\": \"data:image/png;base64,\", \"sizes\": \"512x512\", \"type\": \"image/png\"}  ]})], {type:'application/manifest+json'});
  var mUrl = URL.createObjectURL(mBlob);
  var mLink = document.createElement('link');
  mLink.rel = 'manifest'; mLink.href = mUrl;
  document.head.appendChild(mLink);
} catch(e) {}
</script>
</head>
<body>

<div id="toast" style="display:none;position:fixed;top:20px;left:50%;transform:translateX(-50%);background:#25d366;color:#fff;border-radius:10px;padding:9px 22px;font-weight:700;font-size:14px;z-index:9999;pointer-events:none;white-space:nowrap;"></div>

<div id="backdrop" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:200;" onclick="closeDrawer()"></div>

<div id="drawer" style="position:fixed;top:0;left:0;bottom:0;width:305px;background:linear-gradient(180deg,#0d1e30,#0a1824);border-right:1px solid #1e3a55;z-index:300;display:flex;flex-direction:column;transform:translateX(-100%);transition:transform 0.28s ease;overflow:hidden;">
  <div style="padding:18px;border-bottom:1px solid #1e3a55;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;">
    <div style="display:flex;align-items:center;gap:9px;">
      <div style="width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg,#25d366,#128c7e);display:flex;align-items:center;justify-content:center;font-size:18px;">💬</div>
      <div><div style="color:#fff;font-weight:800;font-size:14px;">WA Parser</div><div style="color:#7aaecc;font-size:11px;">মেনু</div></div>
    </div>
    <button onclick="closeDrawer()" style="background:none;border:none;color:#7aaecc;font-size:24px;line-height:1;padding:4px;">✕</button>
  </div>
  <div id="dBody" style="flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;"></div>
  <div style="padding:10px 18px;border-top:1px solid #1e3a55;font-size:11px;color:#2a4a60;text-align:center;flex-shrink:0;">ভবিষ্যতে আরো ফিচার যোগ হবে</div>
</div>

<!-- Navbar -->
<div style="position:sticky;top:0;z-index:100;background:rgba(13,27,42,0.97);border-bottom:1px solid #1e3a55;padding:10px 16px;display:flex;align-items:center;gap:12px;">
  <button onclick="openDrawer()" style="background:none;border:none;display:flex;flex-direction:column;gap:5px;padding:6px;cursor:pointer;">
    <div style="width:22px;height:2px;background:#7aaecc;border-radius:2px;"></div>
    <div style="width:22px;height:2px;background:#7aaecc;border-radius:2px;"></div>
    <div style="width:22px;height:2px;background:#7aaecc;border-radius:2px;"></div>
  </button>
  <div style="display:flex;align-items:center;gap:10px;flex:1;">
    <div style="background:linear-gradient(135deg,#25d366,#128c7e);border-radius:10px;padding:6px 10px;display:flex;align-items:center;gap:6px;">
      <span style="font-size:18px;">💬</span>
      <div><div style="font-weight:900;font-size:13px;color:#fff;">WA</div><div style="font-size:9px;color:rgba(255,255,255,0.85);letter-spacing:1px;font-weight:700;margin-top:-2px;">PARSER</div></div>
    </div>
    <div style="font-size:11px;color:#7aaecc;line-height:1.4;">নাম্বার ও<br/>এমাউন্ট বের করুন</div>
  </div>
  <div id="badge" style="display:none;background:rgba(37,211,102,0.15);border:1px solid #25d36644;border-radius:8px;padding:4px 10px;font-size:11px;color:#25d366;font-weight:700;"></div>
</div>

<div style="max-width:780px;margin:0 auto;padding:18px 14px;">
  <div class="card">
    <label style="display:block;font-size:12px;color:#7aaecc;font-weight:700;margin-bottom:6px;">হোয়াটসঅ্যাপ মেসেজ এখানে পেস্ট করুন</label>
    <textarea id="inp" oninput="onInp()" placeholder="[13/06, 2:42 pm] Al mamun: 01839693229 bk p, 6,180 tk&#10;..." style="width:100%;height:170px;background:#0c1a28;border:1px solid #244560;border-radius:10px;color:#b8d8f0;font-size:12.5px;padding:13px;resize:vertical;outline:none;font-family:monospace;line-height:1.65;"></textarea>
    <div style="display:flex;gap:10px;margin-top:12px;">
      <button id="pBtn" onclick="doParse()" disabled style="flex:1;background:#1b3348;color:#fff;border:none;border-radius:10px;padding:11px 0;font-size:14px;font-weight:700;opacity:0.5;cursor:not-allowed;">⚡ পার্স করুন</button>
      <button onclick="doClear()" style="background:#1b3348;color:#7aaecc;border:1px solid #244560;border-radius:10px;padding:11px 18px;font-size:14px;font-weight:700;cursor:pointer;">🗑</button>
    </div>
  </div>
  <div id="res"></div>
</div>

<script>
// ── STATE ─────────────────────────────────────────
var S={rows:[],done:false,merge:false};

// ── PARSE ─────────────────────────────────────────
var BN='০১২৩৪৫৬৭৮৯';
function bn2a(s){return s.split('').map(function(c){var i=BN.indexOf(c);return i>=0?String(i):c;}).join('');}
function stripS(s){var p='';while(p!==s){p=s;s=s.replace(/(\d)[\s\-\.](\d)/g,'$1$2');}return s;}
var PRE=/(?:(?:00|\+)?880)?01\d{9}/;

function findPhone(body){
  var cl=stripS(bn2a(body));
  var m=cl.match(PRE);if(!m)return null;
  var d=m[0].replace(/\D/g,'');
  if(d.startsWith('00880'))d=d.slice(5);else if(d.startsWith
